---
import "../styles/global.css";
import type { Lang } from "../i18n/config";

interface Props {
  title: string;
  lang?: Lang;
  description?: string;
}

const { title, lang = "en", description } = Astro.props;

const defaultDescription =
  lang === "es"
    ? "Dalfex — estudio tecnológico colombiano que construye SaaS con IA, apps móviles y automatización."
    : "Dalfex — Colombia-based tech studio building AI-powered SaaS, mobile apps, and automation.";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? defaultDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" hreflang="en" href="https://dalfex.com/" />
    <link rel="alternate" hreflang="es" href="https://dalfex.com/es" />
    <title>{title}</title>
    {/* First-visit language redirect: only from the root path, and only when
        the visitor has no stored preference. The manual EN/ES toggle stores
        the choice so we never fight an explicit selection. */}
    <script is:inline>
      (function () {
        try {
          if (location.pathname !== "/") return;
          var stored = localStorage.getItem("dalfex-lang");
          var pref = stored || (navigator.language || "en").toLowerCase().slice(0, 2);
          if (pref === "es") location.replace("/es");
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-black">
    <slot />
  </body>
</html>
